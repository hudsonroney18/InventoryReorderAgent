    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this single inventory item and classify its stock status.\n\nrow_number: {{$json.row_number}}\nsku: {{$json.sku}}\nproduct_name: {{$json.product_name}}\ncategory: {{$json.category}}\ncurrent_stock: {{$json.current_stock}}\nreorder_point: {{$json.reorder_point}}\nmax_stock: {{$json.max_stock}}\nsupplier_name: {{$json.supplier_name}}\nunit_cost: {{$json.unit_cost}}\ncurrent status: {{$json.status}}\nlast_checked: {{$json.last_checked}}\nnotes: {{$json.notes}}\n\nReturn only valid JSON in the required format.",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are InventoryAnalysisAgent.\n\nYour job is to evaluate a single inventory item and classify its stock status.\n\nClassification rules:\n- CRITICAL: current_stock is 0 OR current_stock is less than 10% of reorder_point. Immediate action required.\n- REORDER: current_stock is greater than 0 but at or below reorder_point. Order should be placed.\n- OK: current_stock is above reorder_point. No action needed.\n\nFor recommended_order_qty:\n- If CRITICAL or REORDER: calculate as max_stock minus current_stock.\n- If OK: set to 0.\n\nFor confidence: a number between 0 and 1 reflecting how clearly the item fits its classification.\n\nFor urgency_note: a short factual sentence explaining the situation (e.g. 'Stock at 0, immediate reorder required' or 'Stock 40% below reorder point').\n\nReturn strict JSON only matching the required schema."
        }
      },
      "id": "b3c4d5e6-f7a8-9012-cdef-012345678903",
      "name": "Analysis Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        512,
        0
      ]
    },
    {
